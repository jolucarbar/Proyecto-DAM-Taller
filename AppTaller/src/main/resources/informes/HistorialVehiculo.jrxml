<jasperReport name="HistorialVehiculo" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6109f325-160c-4d9f-a70b-464ce8f271b1">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion AppTaller"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w1" value="440"/>
	<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w2" value="547"/>
	<parameter name="PARAM_BASTIDOR" class="java.lang.String"/>
	<parameter name="LOGO_PATH" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT r.id_reparacion, r.fecha_entrada, r.estado, e.nombre AS mecanico, r.diagnostico AS notas,
       v.matricula, v.marca, v.modelo
FROM reparaciones r
LEFT JOIN empleados e ON r.empleado_asignado_id = e.id_empleado
LEFT JOIN vehiculos v ON r.vehiculo_bastidor = v.bastidor
WHERE r.vehiculo_bastidor = $P{PARAM_BASTIDOR}
ORDER BY r.fecha_entrada DESC]]></query>
