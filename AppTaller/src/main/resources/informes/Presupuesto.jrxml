<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="Presupuesto" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="52e10fcf-632e-4b95-a15b-db0d9e5081c5">
	<parameter name="ID_PRESUPUESTO" class="java.lang.Integer"/>
	<parameter name="LOGO_PATH" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT 
            p.id_presupuesto, p.fecha_emision, p.total_estimado, p.descripcion_trabajo as averia,
            c.nombre AS cliente_nom, c.dni_cif AS cliente_dni, v.matricula, v.marca, v.modelo,
            'MANO DE OBRA' as tipo_seccion,
            mo.descripcion_trabajo as detalle_desc,
            mo.tiempo_empleado_horas as detalle_cant,
            mo.tarifa_por_hora as detalle_precio,
            mo.subtotal as detalle_subtotal
        FROM presupuestos p
        JOIN clientes c ON p.cliente_dni = c.dni_cif
        JOIN vehiculos v ON p.vehiculo_bastidor = v.bastidor
        LEFT JOIN detalle_mano_obra mo ON p.id_presupuesto = mo.id_presupuesto
        WHERE p.id_presupuesto = $P{ID_PRESUPUESTO}

        UNION ALL

        SELECT 
            p.id_presupuesto, p.fecha_emision, p.total_estimado, p.descripcion_trabajo as averia,
            c.nombre AS cliente_nom, c.dni_cif AS cliente_dni, v.matricula, v.marca, v.modelo,
            'RECAMBIOS' as tipo_seccion,
            prod.nombre as detalle_desc,
            dp.cantidad_usada as detalle_cant,
            dp.precio_venta_unitario as detalle_precio,
            dp.subtotal as detalle_subtotal
        FROM presupuestos p
        JOIN clientes c ON p.cliente_dni = c.dni_cif
        JOIN vehiculos v ON p.vehiculo_bastidor = v.bastidor
        LEFT JOIN detalle_productos dp ON p.id_presupuesto = dp.id_presupuesto
        LEFT JOIN productos prod ON dp.id_producto = prod.id_producto
        WHERE p.id_presupuesto = $P{ID_PRESUPUESTO}]]></query>
	<field name="id_presupuesto" class="java.lang.Integer"/>
	<field name="fecha_emision" class="java.sql.Date"/>
	<field name="total_estimado" class="java.math.BigDecimal"/>
	<field name="averia" class="java.lang.String"/>
	<field name="cliente_nom" class="java.lang.String"/>
	<field name="cliente_dni" class="java.lang.String"/>
	<field name="matricula" class="java.lang.String"/>
	<field name="marca" class="java.lang.String"/>
	<field name="modelo" class="java.lang.String"/>
	<field name="tipo_seccion" class="java.lang.String"/>
	<field name="detalle_desc" class="java.lang.String"/>
	<field name="detalle_cant" class="java.math.BigDecimal"/>
	<field name="detalle_precio" class="java.math.BigDecimal"/>
	<field name="detalle_subtotal" class="java.math.BigDecimal"/>
	<variable name="BaseImponible" class="java.math.BigDecimal">
		<expression><![CDATA[$F{total_estimado}.divide(new java.math.BigDecimal("1.21"), 2, java.math.RoundingMode.HALF_UP)]]></expression>
	</variable>
	<variable name="CuotaIVA" class="java.math.BigDecimal">
		<expression><![CDATA[$F{total_estimado}.subtract($V{BaseImponible})]]></expression>
	</variable>
	<group name="SeccionGrupo">
		<expression><![CDATA[$F{tipo_seccion}]]></expression>
